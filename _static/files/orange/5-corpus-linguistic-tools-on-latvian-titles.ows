stopwords-lv.txt</text>
		<text id="3" type="text/plain" rect="(1117.0, 51.0, 150.0, 57.0)" font-family="Segoe UI" font-size="12">Select a word and send it to the Concordance widget</text>
		<text id="4" type="text/plain" rect="(1145.0, -236.0, 150.0, 57.0)" font-family="Segoe UI" font-size="12">Connect the Concordance widget to the Corpus widget</text>
